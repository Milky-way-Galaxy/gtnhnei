/* === live in-website gtnh-flow Graphviz output === */

.gtnhLiveFlowPanel {
  width: 100%;
}

.gtnhLiveFlowBox {
  border: 1px solid rgba(125, 211, 252, 0.35);
  border-radius: 18px;

  background:
    radial-gradient(circle at 0% 0%, rgba(125, 211, 252, 0.10), transparent 34%),
    linear-gradient(180deg, rgba(9, 22, 40, 0.94), rgba(4, 10, 22, 0.94));

  padding: 14px;
  color: #eaf2ff;
}

.gtnhLiveFlowHead {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;

  padding-bottom: 12px;
  border-bottom: 1px solid rgba(75, 106, 145, 0.55);
}

.gtnhLiveFlowHead h3 {
  margin: 0;
  color: #7dd3fc;
  font-size: clamp(30px, 5vw, 52px);
  line-height: 1;
}

.gtnhLiveFlowHead p {
  margin: 8px 0 0;
  color: #aebbd2;
}

.gtnhLiveFlowBadge {
  border: 1px solid rgba(94, 234, 212, 0.55);
  border-radius: 999px;

  background: rgba(3, 8, 18, 0.72);
  color: #5eead4;

  padding: 7px 11px;
  font-weight: 950;
}

.gtnhLiveFlowActions {
  display: flex;
  flex-wrap: wrap;
  gap: 9px;

  margin: 14px 0;
}

.gtnhLiveFlowActions button {
  border: 1px solid rgba(75, 106, 145, 0.75);
  border-radius: 13px;

  background: linear-gradient(180deg, rgba(19, 34, 58, 0.96), rgba(8, 18, 34, 0.96));
  color: #eaf2ff;

  padding: 9px 12px;
  font-weight: 950;
}

.gtnhLiveFlowStatus {
  margin-bottom: 10px;
  color: #aebbd2;
  font-weight: 850;
}

.gtnhLiveFlowStatus.warn {
  color: #fde68a;
}

.gtnhLiveFlowViewer {
  width: 100%;
  height: min(70vh, 760px);
  min-height: 420px;

  overflow: auto;

  border: 1px solid rgba(75, 106, 145, 0.55);
  border-radius: 16px;

  background: #030914;
  padding: 10px;
}

.gtnhLiveFlowViewer svg,
.gtnhLiveFlowSvg {
  display: block;
  max-width: none;
  min-width: 820px;
  height: auto;

  background: #030914;
}

.gtnhLiveFlowDetails {
  margin-top: 12px;
  color: #cbd5e1;
}

.gtnhLiveFlowDetails summary {
  cursor: pointer;
  color: #facc15;
  font-weight: 950;
}

.gtnhLiveFlowDetails pre,
.gtnhLiveFlowError {
  overflow: auto;

  border: 1px solid rgba(75, 106, 145, 0.55);
  border-radius: 14px;

  background: #020814;
  color: #eaf2ff;

  padding: 12px;
  white-space: pre-wrap;
}

@media (max-width: 700px) {
  .gtnhLiveFlowBox {
    padding: 12px;
  }

  .gtnhLiveFlowViewer {
    height: 62vh;
    min-height: 380px;
  }

  .gtnhLiveFlowViewer svg,
  .gtnhLiveFlowSvg {
    min-width: 860px;
  }
}
